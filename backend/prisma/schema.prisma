datasource db {
  provider = "mysql"
}

generator client {
  provider     = "prisma-client"
  output       = "generated/prisma"
  moduleFormat = "cjs"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  refreshToken String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile             Profile?
  docs                Doc[]
  groups              UserInGroup[]
  activityLogs        ActivityLog[]
  docTypes            DocType[]
  sharedDocs          SharedDoc[]
  accessRequests      AccessRequest[]      @relation("requester")
  accessResponse      AccessRequest[]      @relation("responder")
  notificationToUsers NotificationToUser[]
}

model Profile {
  firstName   String
  lastName    String
  imgUrl      String?
  phoneNumber Int?
  address     String?
  userId      String   @id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Doc {
  id        String        @id @default(uuid())
  name      String
  extension extentionEnum
  ownerId   String
  size      BigInt
  docTypeId String
  addedDate DateTime
  filePath  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  owner      User          @relation(fields: [ownerId], references: [id])
  docType    DocType       @relation(fields: [docTypeId], references: [id])
  sharedDocs SharedDoc[]
  groups     DocsInGroup[]
}

enum extentionEnum {
  pdf
  docx
  mp3
  webp
  mp4
  png
  jpg
  jpeg
}

enum DocStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model DocType {
  id        String   @id @default(uuid())
  name      String   @unique
  creatorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User  @relation(fields: [creatorId], references: [id])
  docs    Doc[]
}

model SharedDoc {
  receiverId     String
  docId          String
  expirationDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  doc      Doc  @relation(fields: [docId], references: [id], onDelete: Cascade)
  receiver User @relation(fields: [receiverId], references: [id])

  @@id([docId, receiverId])
}

model Group {
  id          String      @id @default(uuid())
  creatorId   String
  name        String
  description String
  category    String
  privacy     privacyEnum
  imgUrl      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users               UserInGroup[]
  docs                DocsInGroup[]
  activityLogs        ActivityLog[]
  notificationToUsers NotificationToUser[]
}

enum privacyEnum {
  public
  private
}

model UserInGroup {
  userId    String
  groupId   String
  role      RoleEnum @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@id([groupId, userId])
}

enum RoleEnum {
  creator
  moderator
  user
}

model DocsInGroup {
  groupId        String
  docId          String
  expirationDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  group Group @relation(fields: [groupId], references: [id])
  doc   Doc   @relation(fields: [docId], references: [id])

  @@id([groupId, docId])
}

model ActivityLog {
  id         String     @id @default(uuid())
  userId     String
  groupId    String?
  actionType targetEnum
  targetType String
  targetId   Int
  log        String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  group Group? @relation(fields: [groupId], references: [id])
}

enum targetEnum {
  addDocInGroup
  deleteDocInGroup
  addUserInGroup
  removeUserInGroup
}

model AccessRequest {
  id           String    @id @default(uuid())
  status       String
  message      String
  targetId     Int
  targetType   String
  requesterId  String
  respondedId  String
  responseDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  requester User @relation("requester", fields: [requesterId], references: [id])
  responded User @relation("responder", fields: [respondedId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  type        String
  message     String
  relatedId   Int
  relatedType String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificationToUser {
  notificationId String
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isRead         Boolean

  user         User  @relation(fields: [userId], references: [id])
  notification Group @relation(fields: [notificationId], references: [id])

  @@id([notificationId, userId])
}
